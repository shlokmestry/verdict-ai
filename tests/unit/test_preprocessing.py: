class TestLoanDataPreprocessor:

    def test_clean_data_parses_term(self, sample_df):
        p       = LoanDataPreprocessor()
        cleaned = p.clean_data(sample_df)
        assert cleaned["term"].dtype in ["float64", "int64"]
        assert cleaned["term"].isin([36.0, 60.0]).all()

    def test_engineer_features_creates_expected_columns(self, sample_df):
        p          = LoanDataPreprocessor()
        cleaned    = p.clean_data(sample_df)
        engineered = p.engineer_features(cleaned)
        for col in ["loan_to_income", "installment_to_income",
                    "derogatory_marks", "fico_score", "grade_numeric"]:
            assert col in engineered.columns

    def test_split_proportions(self, sample_df):
        p        = LoanDataPreprocessor()
        cleaned  = p.clean_data(sample_df)
        eng      = p.engineer_features(cleaned)
        encoded  = p.encode_categoricals(eng, fit=True)
        train, val, test = p.split_data(encoded)
        total    = len(train) + len(val) + len(test)
        assert abs(len(train) / total - 0.80) < 0.05
        assert abs(len(val)   / total - 0.10) < 0.05
        assert abs(len(test)  / total - 0.10) < 0.05

    def test_no_target_leak_in_features(self, sample_df):
        p       = LoanDataPreprocessor()
        cleaned = p.clean_data(sample_df)
        eng     = p.engineer_features(cleaned)
        encoded = p.encode_categoricals(eng, fit=True)
        train, _, _ = p.split_data(encoded)
        X       = train.drop(columns=["loan_status"])
        X_scaled = p.scale_features(X, fit=True)
        assert "loan_status" not in X_scaled.columns